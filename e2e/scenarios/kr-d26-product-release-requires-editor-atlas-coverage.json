      "id": "joint-gate-reports-editor-coverage",
      "after": "validate-product-release",
      "category": "EVIDENCE",
      "subject": "product_release.error_codes",
      "matcher": "EQUALS",
      "expected": ["MISSING_PRODUCT_ATLAS_EDITOR_ENTITY"],
