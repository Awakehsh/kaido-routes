      "category": "SAFETY",
      "subject": "product_runtime.status",
      "matcher": "EQUALS",
      "expected": "BLOCKED",
      "rationale": "A product runtime cannot be constructed by bypassing the failed joint release."
    },
    {
      "id": "runtime-retains-joint-gate-error",
      "after": "create-product-runtime",
      "category": "EVIDENCE",
      "subject": "product_runtime.error_codes",
      "matcher": "EQUALS",
      "expected": ["MISSING_PRODUCT_ATLAS_EDITOR_ENTITY"],
      "rationale": "Runtime admission reports the same exact product-authority failure."
    },
    {
