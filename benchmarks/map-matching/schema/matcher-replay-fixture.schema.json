{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaido-routes.example/schema/matcher-replay-fixture-v1.json",
  "title": "Kaido Routes matcher replay fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_id",
    "network_snapshot_id",
    "evidence_classification",
    "configuration",
    "edges",
    "route_occurrences",
    "initial_occurrence_id",
    "observations",
    "ground_truth_intervals",
    "branch_decisions",
    "expected_negative_control_failures"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "fixture_id": { "$ref": "#/$defs/id" },
    "network_snapshot_id": { "$ref": "#/$defs/id" },
    "evidence_classification": { "const": "SYNTHETIC" },
    "configuration": { "$ref": "#/$defs/configuration" },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/edge" }
    },
    "route_occurrences": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/occurrence" }
    },
    "initial_occurrence_id": {
      "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }]
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/observation" }
    },
    "ground_truth_intervals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/truth_interval" }
    },
    "branch_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/branch_decision" }
    },
    "expected_negative_control_failures": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/safety_failure" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ambiguity_margin_meters",
        "stale_observation_threshold_ms",
        "observation_gap_threshold_ms"
      ],
      "properties": {
        "ambiguity_margin_meters": { "type": "number", "minimum": 0 },
        "stale_observation_threshold_ms": { "type": "integer", "minimum": 0 },
        "observation_gap_threshold_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["directed_edge_id", "coordinates"],
      "properties": {
        "directed_edge_id": { "$ref": "#/$defs/id" },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/coordinate" }
        }
      }
    },
    "occurrence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["occurrence_id", "index", "directed_edge_id"],
      "properties": {
        "occurrence_id": { "$ref": "#/$defs/id" },
        "index": { "type": "integer", "minimum": 0 },
        "directed_edge_id": { "$ref": "#/$defs/id" }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observation_id",
        "observed_at_ms",
        "received_at_ms",
        "coordinate",
        "horizontal_accuracy_meters",
        "source"
      ],
      "properties": {
        "observation_id": { "$ref": "#/$defs/id" },
        "observed_at_ms": { "type": "integer", "minimum": 0 },
        "received_at_ms": { "type": "integer", "minimum": 0 },
        "coordinate": { "$ref": "#/$defs/coordinate" },
        "horizontal_accuracy_meters": { "type": "number", "exclusiveMinimum": 0 },
        "course_degrees": {
          "type": "number",
          "minimum": 0,
          "exclusiveMaximum": 360
        },
        "speed_meters_per_second": { "type": "number", "minimum": 0 },
        "source": {
          "enum": ["PHONE", "WIRED_CARPLAY", "WIRELESS_CARPLAY", "ACCESSORY"]
        }
      }
    },
    "truth_interval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_ms",
        "end_ms",
        "directed_edge_id",
        "occurrence_id",
        "classification"
      ],
      "properties": {
        "start_ms": { "type": "integer", "minimum": 0 },
        "end_ms": { "type": "integer", "minimum": 0 },
        "directed_edge_id": { "$ref": "#/$defs/id" },
        "occurrence_id": {
          "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }]
        },
        "classification": { "enum": ["ON_ROUTE", "DEVIATION"] }
      }
    },
    "branch_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "at_ms",
        "planned_outgoing_edge_id",
        "actual_outgoing_edge_id",
        "actual_occurrence_id"
      ],
      "properties": {
        "decision_id": { "$ref": "#/$defs/id" },
        "at_ms": { "type": "integer", "minimum": 0 },
        "planned_outgoing_edge_id": { "$ref": "#/$defs/id" },
        "actual_outgoing_edge_id": { "$ref": "#/$defs/id" },
        "actual_occurrence_id": {
          "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }]
        }
      }
    },
    "safety_failure": {
      "enum": [
        "FALSE_HIGH_CONFIDENCE_EDGE_MATCH",
        "FALSE_HIGH_CONFIDENCE_BRANCH_COMMIT",
        "HIGH_CONFIDENCE_AMBIGUITY",
        "HIGH_CONFIDENCE_STALE_OBSERVATION",
        "ROUTE_OCCURRENCE_UNAVAILABLE",
        "BACKWARD_OCCURRENCE_JUMP",
        "BRANCH_COMMIT_DURING_OBSERVATION_GAP"
      ]
    }
  }
}
