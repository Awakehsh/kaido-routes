      "id": "released-foreground-admits-live-input",
      "after": "evaluate-released-foreground",
      "category": "DOMAIN",
      "subject": "product_runtime_use.foreground_live_input_admitted",
      "matcher": "EQUALS",
      "expected": true,
      "rationale": "This is the only declaration combination eligible to mint the foreground token."
    },
    {
      "id": "released-disabled-is-valid",
      "after": "evaluate-released-disabled",
      "category": "SAFETY",
      "subject": "product_runtime_use.status",
      "matcher": "EQUALS",
      "expected": "PASS",
