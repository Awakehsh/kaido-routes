{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaido-routes.example/schema/osm-selected-path-translation-request-v1.json",
  "title": "Kaido Routes OSM selected-path translation request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "provider_dataset_id",
    "terminal_osm_node_id",
    "route_coordinates",
    "edge_references"
  ],
  "properties": {
    "provider_dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "terminal_osm_node_id": {
      "type": "integer",
      "minimum": 1
    },
    "route_coordinates": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/coordinate"
      }
    },
    "edge_references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/edge_reference"
      }
    }
  },
  "$defs": {
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "edge_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_edge_id",
        "osm_way_id",
        "begin_osm_node_id",
        "is_forward",
        "source_percent_along",
        "target_percent_along"
      ],
      "properties": {
        "provider_edge_id": {
          "type": "string",
          "minLength": 1
        },
        "osm_way_id": {
          "type": "integer",
          "minimum": 1
        },
        "begin_osm_node_id": {
          "type": "integer",
          "minimum": 1
        },
        "is_forward": {
          "type": "boolean"
        },
        "source_percent_along": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "target_percent_along": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
