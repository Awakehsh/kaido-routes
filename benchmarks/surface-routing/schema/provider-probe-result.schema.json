{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaido-routes.example/schema/provider-probe-result-v1.json",
  "title": "Kaido Routes normalized surface-provider probe result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "context",
    "fixture_id",
    "origin_id",
    "request",
    "provider",
    "response_status",
    "evaluations",
    "provider_latency_milliseconds",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "context": {
      "$ref": "#/$defs/context"
    },
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "origin_id": {
      "type": "string",
      "minLength": 1
    },
    "request": {
      "$ref": "#/$defs/request"
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "response_status": {
      "enum": ["SUCCESS", "PROVIDER_FAILURE", "INVALID_RESPONSE"]
    },
    "provider_failure": {
      "$ref": "#/$defs/provider_failure"
    },
    "evaluations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evaluation"
      }
    },
    "provider_latency_milliseconds": {
      "type": "integer",
      "minimum": 0
    },
    "decision": {
      "enum": ["PASS", "FAIL"]
    }
  },
  "$defs": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "requested_at", "environment", "retention_classification"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "requested_at": {
          "type": "string",
          "format": "date-time"
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "retention_classification": {
          "enum": [
            "RAW_LOCAL_ONLY",
            "SCALAR_LOCAL_ONLY",
            "REVIEWED_SCALARS",
            "REVIEWED_DERIVED_FIXTURE"
          ]
        }
      }
    },
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_id",
        "coordinate",
        "directed_surface_edge_id",
        "expected_bearing_degrees",
        "bearing_tolerance_degrees",
        "max_terminal_distance_meters"
      ],
      "properties": {
        "anchor_id": {
          "type": "string",
          "minLength": 1
        },
        "coordinate": {
          "$ref": "#/$defs/coordinate"
        },
        "directed_surface_edge_id": {
          "type": "string",
          "minLength": 1
        },
        "expected_bearing_degrees": {
          "type": "number"
        },
        "bearing_tolerance_degrees": {
          "type": "number"
        },
        "max_terminal_distance_meters": {
          "type": "number"
        }
      }
    },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["avoid_highways", "avoid_tolls", "request_alternatives"],
      "properties": {
        "avoid_highways": {
          "type": "boolean"
        },
        "avoid_tolls": {
          "type": "boolean"
        },
        "request_alternatives": {
          "type": "boolean"
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "origin_id",
        "origin",
        "entrance_facility_id",
        "selected_join_occurrence_id",
        "destination_anchor",
        "preferences"
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "origin_id": {
          "type": "string",
          "minLength": 1
        },
        "origin": {
          "$ref": "#/$defs/coordinate"
        },
        "entrance_facility_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_join_occurrence_id": {
          "type": "string",
          "minLength": 1
        },
        "destination_anchor": {
          "$ref": "#/$defs/anchor"
        },
        "preferences": {
          "$ref": "#/$defs/preferences"
        }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_id", "adapter_version", "data_review_status"],
      "properties": {
        "provider_id": {
          "type": "string",
          "minLength": 1
        },
        "adapter_version": {
          "type": "string",
          "minLength": 1
        },
        "provider_version": {
          "type": "string",
          "minLength": 1
        },
        "data_review_status": {
          "enum": [
            "REVIEW_REQUIRED",
            "SCALAR_RETENTION_REVIEWED",
            "DERIVED_FIXTURE_REVIEWED"
          ]
        }
      }
    },
    "provider_failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": [
            "NO_ROUTE",
            "NETWORK",
            "THROTTLED",
            "SERVER",
            "CANCELLED",
            "INVALID_REQUEST",
            "UNKNOWN"
          ]
        },
        "provider_error_code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disposition", "hard_gates"],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "candidate": {
          "$ref": "#/$defs/candidate"
        },
        "inspection": {
          "$ref": "#/$defs/inspection"
        },
        "inspection_latency_milliseconds": {
          "type": "integer",
          "minimum": 0
        },
        "disposition": {
          "enum": ["ACCEPTED", "REJECTED", "PROVIDER_FAILURE", "INVALID_RESPONSE"]
        },
        "hard_gates": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": {
            "$ref": "#/$defs/hard_gate"
          }
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "instruction", "distance_meters"],
      "properties": {
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string"
        },
        "notice": {
          "type": "string"
        },
        "distance_meters": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "provider_id",
        "coordinates",
        "steps",
        "distance_meters",
        "expected_travel_time_seconds",
        "advisory_notices"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "provider_id": {
          "type": "string",
          "minLength": 1
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/coordinate"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/step"
          }
        },
        "distance_meters": {
          "type": "number",
          "minimum": 0
        },
        "expected_travel_time_seconds": {
          "type": "number",
          "minimum": 0
        },
        "has_highways": {
          "type": "boolean"
        },
        "has_tolls": {
          "type": "boolean"
        },
        "advisory_notices": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selected_path_evidence": {
          "$ref": "#/$defs/selected_path_evidence"
        }
      }
    },
    "selected_path_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_snapshot_id",
        "provider_dataset_id",
        "directed_edge_ids"
      ],
      "properties": {
        "network_snapshot_id": {
          "type": "string",
          "minLength": 1
        },
        "provider_dataset_id": {
          "type": "string",
          "minLength": 1
        },
        "directed_edge_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "anchor_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_id",
        "directed_surface_edge_id",
        "terminal_distance_meters",
        "terminal_bearing_degrees"
      ],
      "properties": {
        "anchor_id": {
          "type": "string",
          "minLength": 1
        },
        "directed_surface_edge_id": {
          "type": "string",
          "minLength": 1
        },
        "terminal_distance_meters": {
          "type": "number",
          "minimum": 0
        },
        "terminal_bearing_degrees": {
          "type": "number"
        }
      }
    },
    "inspection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "anchor_binding": {
          "$ref": "#/$defs/anchor_binding"
        },
        "geometry_binding_is_unambiguous": {
          "type": "boolean"
        },
        "expressway_edge_ids_before_entry": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "crossed_toll_domain_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unmatched_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "ambiguous_directed_edge_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "disconnected_directed_edge_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "resolved_path_edge_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "hard_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "status", "reason_codes"],
      "properties": {
        "gate": {
          "enum": [
            "CORRECT_DIRECTED_APPROACH",
            "NO_EARLY_EXPRESSWAY",
            "COMPATIBLE_ROUTE_JOIN",
            "ALLOWED_TOLL_DOMAIN",
            "GEOMETRY_BINDABLE",
            "HONEST_PROVIDER_STATUS"
          ]
        },
        "status": {
          "enum": ["PASS", "FAIL", "NOT_EVALUATED"]
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
