      "category": "SAFETY",
      "subject": "journey.strict_route_auto_commit_allowed",
      "matcher": "EQUALS",
      "expected": false,
      "rationale": "The app must remain honest when GPS is weak near tunnels or stacked roads."
    },
    {
      "id": "reason-is-visible",
      "after": "entry-region-observed",
      "category": "UI",
      "subject": "journey.ambiguity_reason",
      "matcher": "EQUALS",
      "expected": "GEOFENCE_ONLY_NO_DIRECTED_RAMP_MATCH",
      "rationale": "A low-confidence mode must be explainable rather than silently snapping."
    },
    {
      "id": "no-phone-touch-required",
      "after": "entry-region-observed",
      "category": "SAFETY",
      "subject": "ui.requires_phone_touch_while_moving",
      "matcher": "EQUALS",
      "expected": false,
      "rationale": "A manual fallback may use a safe voice or CarPlay action but cannot demand phone interaction while moving."
    },
    {
      "id": "route-target-remains-visible",
      "after": "entry-region-observed",
      "category": "UI",
      "subject": "guidance.shows_entry_route_shield_and_direction",
      "matcher": "EQUALS",
      "expected": true,
      "rationale": "The driver still needs the planned sign target while the phase is uncertain."
