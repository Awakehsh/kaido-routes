      "subject": "product_release.missing_editor_entity_ids",
      "matcher": "EQUALS",
      "expected": ["test.approach.product-release.exit"],
      "rationale": "The gate names the exact reviewed incoming approach rather than a display label or JCT pin."
    },
    {
      "id": "invalid-product-cannot-create-runtime",
