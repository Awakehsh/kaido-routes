{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaido-routes.example/schema/osm-way-point-path-translation-request.schema.json",
  "title": "Kaido Routes OSM way point-pair translation request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "provider_dataset_id",
    "route_coordinates",
    "segment_identities"
  ],
  "properties": {
    "provider_dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "route_coordinates": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/coordinate"
      }
    },
    "segment_identities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/segmentIdentity"
      }
    }
  },
  "$defs": {
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "segmentIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_directed_edge_key", "osm_way_id"],
      "properties": {
        "provider_directed_edge_key": {
          "type": "integer",
          "minimum": 0
        },
        "osm_way_id": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
