{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaido-routes.example/schema/surface-routing-build-manifest.schema.json",
  "title": "Kaido Routes surface-routing build manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "created_at",
    "intended_use",
    "network_snapshot_id",
    "provider_dataset_id",
    "engine_build",
    "sources",
    "artifacts",
    "capabilities",
    "admin_verifications",
    "release_blockers"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "manifest_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "created_at": {
      "$ref": "#/$defs/timestamp"
    },
    "intended_use": {
      "enum": ["LAB_ONLY", "RELEASE_CANDIDATE"]
    },
    "network_snapshot_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "provider_dataset_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "engine_build": {
      "$ref": "#/$defs/engineBuild"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "capabilities": {
      "$ref": "#/$defs/capabilities"
    },
    "admin_verifications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adminVerification"
      }
    },
    "release_blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "engineBuild": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build_id",
        "provider_id",
        "provider_version",
        "container_image",
        "container_digest"
      ],
      "properties": {
        "build_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "provider_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "provider_version": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "container_image": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "container_digest": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "roles",
        "snapshot_at",
        "uri",
        "sha256",
        "byte_count",
        "licence",
        "attribution"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["ROAD_NETWORK", "ADMINISTRATION", "TIME_ZONE"]
          }
        },
        "snapshot_at": {
          "$ref": "#/$defs/timestamp"
        },
        "uri": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "byte_count": {
          "type": "integer",
          "minimum": 1
        },
        "licence": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "attribution": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "role", "relative_path", "format", "sha256", "byte_count"],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "role": {
          "enum": [
            "PROVIDER_CONFIGURATION",
            "ENGINE_BINARY",
            "ROUTING_TILES",
            "ADMINISTRATION_DATABASE",
            "TIME_ZONE_DATABASE",
            "KAIDO_DIRECTED_GRAPH"
          ]
        },
        "relative_path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//).+$"
        },
        "format": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "byte_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "includes_administrative_data",
        "includes_time_zone_data",
        "keeps_all_osm_node_ids"
      ],
      "properties": {
        "includes_administrative_data": {
          "type": "boolean"
        },
        "includes_time_zone_data": {
          "type": "boolean"
        },
        "keeps_all_osm_node_ids": {
          "type": "boolean"
        },
        "selected_path_identity": {
          "enum": ["OSM_NODE_PATH", "OSM_WAY_POINT_PAIRS"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "keeps_all_osm_node_ids": {
                "const": false
              }
            },
            "required": ["keeps_all_osm_node_ids"]
          },
          "then": {
            "required": ["selected_path_identity"],
            "properties": {
              "selected_path_identity": {
                "const": "OSM_WAY_POINT_PAIRS"
              }
            }
          }
        }
      ]
    },
    "adminVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "coordinate",
        "expected_region_code",
        "observed_country_code",
        "observed_state_code",
        "drive_on_right",
        "checked_at",
        "evidence_sha256"
      ],
      "properties": {
        "check_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "coordinate": {
          "$ref": "#/$defs/coordinate"
        },
        "expected_region_code": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "observed_country_code": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "observed_state_code": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "drive_on_right": {
          "type": "boolean"
        },
        "checked_at": {
          "$ref": "#/$defs/timestamp"
        },
        "evidence_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
